# SADT PoC — salin ke backend/.env atau export di shell
# Lebih mudah: cd backend && python scripts/apply_env_preset.py gpu.8gb
# Preset: env/mac.lab.env | gpu.6gb.env | gpu.8gb.env | gpu.12gb.env | gpu.demo-fast.env
# Semua env memakai prefix SADT_

# Network (default loopback — aman untuk lab)
# SADT_API_HOST=127.0.0.1
# SADT_API_PORT=8000
# SADT_UI_PORT=5173

# Seed password lab (hanya dipakai saat DB users kosong)
# Ganti sebelum deploy di luar localhost
# SADT_SEED_OPERATOR_PASSWORD=Ops@2026
# SADT_SEED_ANALIS_PASSWORD=Analis@2026
# SADT_SEED_PIMPINAN_PASSWORD=Pimpinan@2026
# SADT_SEED_ADMIN_PASSWORD=Admin@2026

# Upload ZIP hasil ADB (analisa tanpa akuisisi live)
# SADT_ZIP_ENABLED=1
# SADT_ZIP_MAX_MB=512

# ---- Preset: Mac lab (CPU) ----
# SADT_OCR_ENABLED=1
# SADT_OCR_BACKEND=easyocr
# SADT_OCR_GPU=0
# SADT_MEDIA_TEXT_ENABLED=1
# SADT_OCR_FULL_GALLERY=1
# SADT_WORKER_CONCURRENCY=4
# SADT_OCR_MAX_EDGE_PX=1280
# SADT_VIDEO_WHISPER_MAX_DURATION_S=180

# ---- Preset: GPU full (panitia, akurasi) ----
# python run.py --gpu  # set banyak default otomatis
# SADT_OCR_BACKEND=paddleocr
# SADT_OCR_GPU=1
# SADT_IMAGE_CAP_FULL=5000
# SADT_VIDEO_CAP_FULL=0
# SADT_OCR_FULL_GALLERY=1
# SADT_WORKER_CONCURRENCY=6
# SADT_GPU_WHISPER_MODEL=base
# SADT_VIDEO_OVERLAY_KEYFRAMES=5
# SADT_VIDEO_WHISPER_MAX_DURATION_S=300

# ---- Preset: GPU cepat (demo singkat) ----
# SADT_OCR_FULL_GALLERY=0
# SADT_GPU_WHISPER_MODEL=tiny
# SADT_VIDEO_OVERLAY_KEYFRAMES=2
# SADT_VIDEO_WHISPER_MAX_DURATION_S=120
# SADT_IMAGE_CAP_QUICK=800
# SADT_VIDEO_CAP_QUICK=40

# OCR / media teks
# SADT_OCR_LANGS=en
# SADT_GPU_WHISPER_ENABLED=1
# SADT_GPU_WHISPER_LANG=id

# Tuning volume & paralelisme
# SADT_IMAGE_CAP_QUICK=800
# SADT_IMAGE_CAP_FULL=3000
# SADT_VIDEO_CAP_QUICK=80
# SADT_VIDEO_CAP_FULL=0
# SADT_CV_BATCH_SIZE=16
# SADT_OCR_MAX_EDGE_PX=1280
# SADT_VIDEO_WHISPER_MAX_DURATION_S=300

# Full GPU moderation stack (juga diaktifkan oleh: python run.py --gpu)
# SADT_GPU_STACK_ENABLED=0
# SADT_GPU_SAFEWATCH_ENABLED=1
# SADT_GPU_SAFEWATCH_MODEL=
# SADT_GPU_ICM_ENABLED=1
# SADT_GPU_ICM_MODEL=
# SADT_GPU_QWEN_ENABLED=1
# SADT_GPU_QWEN_MODEL=Qwen/Qwen2.5-VL-7B-Instruct

# Acceptance
# SADT_PERF_SLA_MS=120000
# SADT_REQUIRE_GPU=0
