# SADT PoC — salin ke backend/.env atau export di shell
# Semua env memakai prefix SADT_

# Network (default loopback — aman untuk lab)
# SADT_API_HOST=127.0.0.1
# SADT_API_PORT=8000
# SADT_UI_PORT=5173

# Seed password lab (hanya dipakai saat DB users kosong)
# Ganti sebelum deploy di luar localhost
# SADT_SEED_OPERATOR_PASSWORD=Ops@2026
# SADT_SEED_ANALIS_PASSWORD=Analis@2026
# SADT_SEED_PIMPINAN_PASSWORD=Pimpinan@2026
# SADT_SEED_ADMIN_PASSWORD=Admin@2026

# Upload ZIP hasil ADB (analisa tanpa akuisisi live)
# SADT_ZIP_ENABLED=1
# SADT_ZIP_MAX_MB=512

# OCR / GPU stack
# SADT_OCR_ENABLED=0
# SADT_OCR_BACKEND=paddleocr
# SADT_OCR_GPU=1
# SADT_OCR_LANGS=en

# Full GPU moderation stack (juga diaktifkan oleh: python run.py --gpu)
# SADT_GPU_STACK_ENABLED=0
# SADT_GPU_SAFEWATCH_ENABLED=1
# SADT_GPU_SAFEWATCH_MODEL=
# SADT_GPU_ICM_ENABLED=1
# SADT_GPU_ICM_MODEL=
# SADT_GPU_QWEN_ENABLED=1
# SADT_GPU_QWEN_MODEL=Qwen/Qwen2.5-VL-7B-Instruct
# SADT_GPU_WHISPER_ENABLED=1
# SADT_GPU_WHISPER_MODEL=base
# SADT_GPU_WHISPER_LANG=id

# Acceptance
# SADT_PERF_SLA_MS=120000
# SADT_REQUIRE_GPU=0
